function auto_heal()
{
    while(!Player.Dead())
    {

                      if (Player.Hits() < Player.MaxHits() - 10) 
                      {               
                            Orion.Say(".bandageself");
                            Orion.WaitJournal('Leceni se nezdarilo|Prvni pomoc se podarila|Neni treba lecit|Targeting|Prerusil jsi pokus o leceni', Orion.Now(), Orion.Now()+10000, 'My|Sys');
                            Orion.Wait(200);   
                            Orion.Attack('lastattack');                             
                      }
                      
                      if (Player.Hits() < 40) 
                      {                
                            if (Orion.Count('0x1f49') > 1)
                            {
                            Orion.WaitTargetObject('self');        
                            Orion.Say('.svitek ivm');
                            Orion.Wait(1500);  
                            Orion.Attack('lastattack');         
                            }
                            else
                            {
                            Orion.Print("DOSLY SVITKY") 
                            Orion.WaitTargetObject('self');       
                            Orion.Cast('Greater Heal')
                            Orion.Wait(2000);
                            Orion.Attack('lastattack');
                            }                            
                      } 
                      
                      if (Player.Hits() < 25) 
                      {                
                            Orion.Say(".lektvar Greater heal potion");                              
                            Orion.Wait(400);  
                            Orion.Attack('lastattack');                          
                      } 
                      
                      if (Player.Hits() < 15) 
                      {                
                            Orion.Say('.jidlo pizza sunkova');                              
                            Orion.Wait(400);  
                            Orion.Attack('lastattack');                          
                      }
                      Orion.Wait(500);
    }
}

