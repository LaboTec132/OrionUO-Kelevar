function AutoLoot()
 {
 Orion.CharPrint(self, "82", "** Loot Zapnut **");
 Orion.ClearJournal();
     while(!Player.Dead())
    {        
        if (Orion.InJournal("mrtvola"))
           {  
           Orion.ClearJournal();           
           var container = Orion.FindObject("lootsacek");
           if (!container)
           {
               Orion.CharPrint(self, "42", "Oznac loot sacek");
               Orion.AddObject("lootsacek");
               Orion.Wait(100);
               while (Orion.HaveTarget())
               {
                  Orion.Wait(100);
               }
           }
        Orion.Wait(500);
        var list = Orion.FindList('lootlist', lastcontainer); 
        for (var i = 0; i < list.length; i++)
        {      
              Orion.DragItem(list[i], 0);
              Orion.Wait(300);
              Orion.DropDraggedItem("lootsacek");
              Orion.Wait(600);
        }            
Orion.Print('** Loot Dokoncen **');           
           }

    }    
}
























































































































function VYROBA_INSC_ZEMETRAS()
 {
 
    var container = Orion.FindObject("bedna_s_blankama");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac bednu s blankama");
        Orion.AddObject("bedna_s_blankama"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("bedna_na_regy");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac bednu na regy");
        Orion.AddObject("bedna_na_regy"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
 
     while(!Player.Dead())
    {
    
        if (Orion.Count("0x1F65", "0x0000") > 500)  // ZEMETRAS SVITKY
        {           
            Orion.UseObject("bedna_s_blankama")
            Orion.Wait(800);
            Orion.MoveItem(Orion.FindType('0x1F65', '0x0000', backpack)[0], (0 - Orion.Count('0x1F65', '0x0000', "bedna_s_blankama")), "bedna_s_blankama");        
        }
        
        if (Orion.Count("0x0E34", "0x0000") < 10)  // BLANKY
        {           
            Orion.UseObject("bedna_s_blankama")
            Orion.Wait(800);
            Orion.MoveItem(Orion.FindType('0x0E34', '0x0000', 'bedna_s_blankama')[0], (500 - Orion.Count('0x0E34', '0x0000', backpack)), backpack);        
        }
    
        if (Orion.Count('0x0F7B') < 10)  // BM
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_regy")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(102)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
        }
        
        if (Orion.Count('0x0F85') < 10)  // Gi
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_regy")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(104)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
        }
        
        if (Orion.Count('0x0F86') < 10)  // MR
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_regy")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(105)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
        }
        
        if (Orion.Count('0x0F8C') < 10)  // SA
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_regy")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(107)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
        }
    
        Orion.ClearJournal();   
        Orion.CancelWaitMenu();          
          
        if (Player.Mana() > 55)
           {          
            Orion.CancelWaitMenu();    
            Orion.Wait(100); 
                if (Orion.WaitForMenu(1000))
                {         
                    Orion.CloseMenu("Spell Circles");
                    Orion.Wait(300);
                    Orion.CloseMenu("Spell Circle");		
                }
            Orion.Wait(100);
            Orion.CancelWaitMenu();
            Orion.WaitMenu("Spell Circles", "Eighth Circle");
            Orion.UseType("0x0E34");
            Orion.Wait(500);
	            if (Orion.WaitForMenu(1000))
	            {
                    Orion.SelectMenu("Spell Circle 8", "Earthquake");
                }           
            
 
            Orion.Wait(400);
            Orion.WaitJournal('Vkladas|Nepodarilo se', Orion.Now(), Orion.Now()+10000, 'My|Sys');             
            }       
         
         Orion.Wait(100);
         
         if (Player.Mana() <= 55) {
           Orion.UseSkill("Meditation")
           Orion.Wait(400);
           Orion.WaitJournal('Tva magicka energie|Ztratil si', Orion.Now(), Orion.Now()+20000, 'My|Sys');        
         }   
            

    }    
}

