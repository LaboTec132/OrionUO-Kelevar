function AutoLoot_mutagen_V_2()
{
    Orion.CharPrint(self, "82", " Loot Zapnut ");
    var container = Orion.FindObject("lootsacek");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac loot sacek");
        Orion.AddObject("lootsacek");
        Orion.Wait(100);
        while (Orion.HaveTarget())
            Orion.Wait(100);
    }
    Orion.ClearIgnoreList('vylooteno');
    Orion.UseIgnoreList('vylooteno');
    while(!Player.Dead())
    {
        var lDeadBodies = Orion.FindType('0x2006', '-1', 'ground', '2');
        for (var i = 0; i < lDeadBodies.length; i++)
        {
                  Orion.OpenContainer(lDeadBodies[i]);
            Orion.Wait(350);
            lLootList = Orion.FindList('lootlist', lDeadBodies[i]);
            for (var y = 0; y < lLootList.length; y++)
            {
                Orion.DragItem(lLootList[y], 0);
                Orion.Wait(297);
                Orion.DropDraggedItem("lootsacek");
                Orion.Wait(200);
            }
            Orion.AddIgnoreListObject('vylooteno', lDeadBodies[i]);
            Orion.CharPrint(self, "82", " Loot Dokoncen ");
        }
        Orion.Wait(500);
    }
}
       
