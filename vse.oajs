function Mapa_na_vodu_S_N()
 {
 
 var mapa = Orion.FindObject("mapanavodu");
    if (!mapa)
    {
        Orion.CharPrint(self, "42", "Oznac mapu");
        Orion.AddObject("mapanavodu");
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    

    
       Orion.ClearJournal(); 
       while (!Orion.InJournal("prut|Huraa|Huraa!" , 'sys|my')) {
                   Orion.UseObject("mapanavodu");   
                   Orion.WaitTargetTileRelative('mine', 0, -3, 1);
                   Orion.Wait(200);
                   Orion.UseObject("mapanavodu");   
                   Orion.WaitTargetTileRelative('mine', 0, 3, 1);
                   Orion.Wait(1200);
       }  
       Orion.CharPrint(self, "42", "*** POKLAD ***");
       Orion.CharPrint(self, "52", "*** POKLAD ***");
       Orion.Say('stop');
       Orion.Wait(200);
       Orion.Say('.lektvar Invisibility potion');
}

