function Loot()
{

    var container = Orion.FindObject("lootsacek");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac loot sacek");
        Orion.AddObject("lootsacek");
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var list = Orion.FindList('lootlist', lastcontainer); 
    for (var i = 0; i < list.length; i++)
    {      
       Orion.DragItem(list[i], 0);
       Orion.Wait(300);
       Orion.DropDraggedItem("lootsacek");
       Orion.Wait(600);
    }  

Orion.CharPrint(self, "72", "--- DOLOCENO ---");        
Orion.Print('** Loot Dokoncen **');
}

