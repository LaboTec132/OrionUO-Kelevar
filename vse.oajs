        Orion.AddObject("bedna_na_regy"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("mortar");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac mortar");
        Orion.AddObject("mortar"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
        
 
     while(!Player.Dead())
    {
    
        if (Orion.Count('0x0F78') < 10)  // Batwing
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_regy")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(111)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
        }
        
        if (Orion.Count("0x0F0E", "0x0000") < 25)  // Prazdny flasky
        {           
            Orion.UseObject("bedna_s_flaskama")
            Orion.Wait(1000);
            Orion.MoveItem(Orion.FindType('0x0F0E', '0x0000', "bedna_s_flaskama")[0], (200 - Orion.Count('0x0F0E', '0x0000', backpack)), backpack);  
         }
         
         if (Orion.Count("0x0F09", "0x0979") > 50)  // Shrink flasky
        {           
            Orion.UseObject("bedna_s_flaskama")
            Orion.Wait(1000);
            Orion.MoveItem(Orion.FindType('0x0F09', '0x0979', backpack)[0], (0 - Orion.Count('0x0F09', '0x0979', "bedna_s_flaskama")), "bedna_s_flaskama");  
         }
      
        
        Orion.ClearJournal();
        Orion.CancelWaitMenu();
        Orion.WaitMenu("What sort of potion do you", "Shrink potion");
        Orion.UseObject("mortar");
        Orion.WaitJournal('Vkladas|Nepovedlo se', Orion.Now(), Orion.Now()+120000, 'My|Sys');    
        Orion.Wait(500);         

    }    
}

