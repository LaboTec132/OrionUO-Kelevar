function Vyroba_cooking_sunka()
 {
 
    var container = Orion.FindObject("kucharka");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac kucharku");
        Orion.AddObject("kucharka"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("bedna_na_jidlo");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac bednu na jidlo");
        Orion.AddObject("bedna_na_jidlo"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("bedna_s_regama");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac bednu s regama");
        Orion.AddObject("bedna_s_regama"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("krb");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac krb");
        Orion.AddObject("krb"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
     while(!Player.Dead())
    {  

    
        
        if (Orion.Count('0x09C9') > 200)  // SUNKA
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_jidlo")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(3)); 
            Orion.WaitTargetType("0x09C9");
            Orion.Wait(800);        
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));  
            Orion.Wait(300); 
        }
        
        if (Orion.Count('0x09F1') < 25)  // Cut of raw ribs
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_jidlo")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(110)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(110));
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(110));
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
            Orion.Wait(300); 
        }
        
        Orion.ClearJournal();   
        Orion.CancelWaitMenu(); 
        Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("kucharka")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(116)); 
            Orion.Wait(800);
            var Gump;
