function undress()
{	
	Orion.Ignore("0x412BA128");
	Orion.Undress("Damascenes");
	Orion.Wait(100);
}

function delete_ignore_list()
{
	Orion.ClearIgnoreList('vylooteno');
     Orion.Wait(200);     
}
            
function Autostart()
{
     Orion.Wait(9000)
	Orion.Exec("Hledani_ebony_silver");
	Orion.Wait(20);
     Orion.Exec("AutoLoot_mutagen_V_2");
     Orion.Wait(20);
     Orion.Exec("Hledani_houba");
}