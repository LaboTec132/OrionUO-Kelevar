function targetdraka() {
    Orion.Ignore(self);
    var target = Orion.FindType("0x02CE", "0x0B24", "ground", "mobile", 10, "gray");
    if (target.length != 0) {
        Orion.AddObject("drak", target);
        Orion.ShowStatusbar("drak", 850,744)
        Orion.Ignore(target[0]);
    } else {
        Orion.IgnoreReset();
        Orion.Ignore(self);
        target = Orion.FindType("0x02CE", "0x0B24", "ground", "mobile", 10, "gray");
        if (target.length != 0) {
            Orion.AddObject("drak", target); 
            Orion.ShowStatusbar("drak", 850,744)      
            Orion.Ignore(target[0]);
        }
    }
}

function drakrozbaleni()
{
    var rightHandObj = Orion.ObjAtLayer("RightHand");
    var leftHandObj = Orion.ObjAtLayer("LeftHand");
    
    if (Player.Weight() > Player.MaxWeight() - 1)   
       {
       Orion.CharPrint(self, "42", "****! PRETIZENI !****");
       Orion.CharPrint(self, "52", "****! PRETIZENI !****");  
       Orion.CharPrint(self, "42", "****! PRETIZENI !****");               
        }
    else
        {       
       Orion.Equip('0x41B11647');
       Orion.Wait(10);
       Orion.UseType("0x20D6")
       Orion.Wait(300);
       Orion.Say("all come")
       Orion.Exec('targetdraka');
       Orion.Wait(500);
        }    
        
    if (rightHandObj)
    {
        Orion.Equip(rightHandObj.Serial());
        Orion.Wait(600);
    }
    
    if (leftHandObj)
    {
        Orion.Equip(leftHandObj.Serial());
        Orion.Wait(600);
    }
}

function drakbandy()
{
    while(!Player.Dead())
    {
            Orion.ClearJournal();
            Orion.WaitTargetObject('drak');
            Orion.UseType('0x0E21');
            Orion.Wait(500);            
            if (Orion.InJournal("Nepotrebuje vylecit", 'sys')) {
            Orion.CharPrint(self, "42", "** OK VYPINAM **");
            Orion.Terminate('drakbandy');  
            }
            if (Orion.InJournal("Jdi bliz!", 'sys')) {
            Orion.CharPrint(self, "42", "****! Jdi blize !****");
            Orion.Wait(1000); 
            Orion.Exec('spoustecbandu');
            }
            Orion.ClearJournal();
            while (!Orion.InJournal("podarila", 'sys')) {
                Orion.Wait(1000);
            }
    }
}

function Taming()
{ 
    Orion.AddObject("tamovany");
    Orion.CharPrint(self, "42", "Koho chces tamovat?");
    Orion.Print("Koho chces tamovat?");
	Orion.PauseScript("Hledani_mustang_jesterka");

    while (Orion.HaveTarget())
    {
        Orion.Wait(100);
    }

    Orion.Wait(300);
          
    while(!Player.Dead())
    {       
            Orion.ClearJournal();        
            Orion.WaitTargetObject('tamovany');
            Orion.UseSkill('Animal Taming'); 
            Orion.WaitJournal('nepodarilo|ochocen|preruseno|zmizel z oci', Orion.Now(), Orion.Now()+80000, 'My|Sys'); 
            Orion.Wait(500);  
            Orion.Wait(200);

                if (Orion.InJournal('ochocen', 'sys')) {
                    Orion.CharPrint(self, "42", "****! HOTOVO - VYPINAM !****");
                    Orion.Wait(1000); 
			Orion.ResumeScript("Hledani_mustang_jesterka");
                    Orion.Terminate('Taming');
	               Orion.Wait(100);
                    Orion.Wait(100);
                }  
                if (Orion.InJournal('preruseno', 'sys')) {
                    Orion.CharPrint(self, "42", "****! PRERUSENO - VYPINAM !****");
                    Orion.Wait(1000); 
                Orion.ResumeScript("Hledani_mustang_jesterka");
                    Orion.Terminate('Taming');
                    Orion.Wait(100);
                    Orion.Wait(100);
                } 
                if (Orion.InJournal('zmizel z oci', 'sys')) {
                    Orion.CharPrint(self, "42", "****! MIMO DOSAH - VYPINAM !****");
                    Orion.Wait(1000); 
                Orion.ResumeScript("Hledani_mustang_jesterka");
                    Orion.Terminate('Taming');
                    Orion.Wait(100);
                }                 
    }                  
}

function uspavani()
{    

    var rightHandObj = Orion.ObjAtLayer("RightHand");
    var leftHandObj = Orion.ObjAtLayer("LeftHand");

    Orion.WarMode("off")
          
    while(!Player.Dead())
    {       
            Orion.ClearJournal();    

            Orion.WaitTargetObject('cil');
            Orion.UseSkill('Discordance'); 
            Orion.WaitJournal("Takhle daleko jeste nedokazes|Nepodarilo|Prestal jsi hrat|rozdrazdila|Uspesne jsi unavil|see the target|Zaobiras se bojem|uz je unaveny dost", Orion.Now(), Orion.Now()+20000, "my|sys"); 
            Orion.Wait(500); 

                if (Orion.InJournal('Uspesne jsi unavil', 'sys')) {
                    Orion.CharPrint(self, "42", "****! HOTOVO - VYPINAM !****");
                    Orion.Wait(100); 
                    if (rightHandObj)
                    {
                        Orion.Equip(rightHandObj.Serial());
                        Orion.Wait(600);
                    }

                    if (leftHandObj)
                    {
                        Orion.Equip(leftHandObj.Serial());
                        Orion.Wait(100);
                    }
                    Orion.Terminate('uspavani');
                }  
                
                if (Orion.InJournal('Takhle daleko jeste nedokazes', 'sys')) {
                    Orion.CharPrint(self, "42", "****! JDI BLIZ !****");
                    Orion.Wait(1000);                    
                }     
                
                if (Orion.InJournal('Zaobiras se bojem', 'sys|my')) {                    
                    Orion.Wait(200);
                    Orion.WarMode("off")                                       
                }   
                
                if (Orion.InJournal('see the target', 'sys')) {
                    Orion.CharPrint(self, "42", "****! NEVIDIM USPAVANEHO - VYPINAM !****");
                    Orion.Wait(200); 
                    Orion.Terminate('uspavani');
                }   
                
                if (Orion.InJournal('uz je unaveny dost', 'sys')) {
                    Orion.CharPrint(self, "42", "****! UZ JE USPANEJ - VYPINAM !****");
                    Orion.Wait(200); 
                    Orion.Terminate('uspavani');
                }                                    
    }                  
}

