function rezani() 
{
    if (!Player.Dead()) 
    {
           var corpses = Orion.FindType('0x2006', '-1', ground, '', 'usedistance');
            for (var c = 0; c < corpses.length; c++) 
            {
                   Orion.OpenContainer(corpses[c])
                   Orion.Wait(200);
                   Orion.WaitTargetObject(corpses[c]);
                   Orion.UseObject('ba');
                Orion.ResetIgnoreList();
                Orion.Wait(200);
                Orion.Ignore(corpses[c]);
                   Orion.Wait(200);
            }
            Orion.Wait(200);
      }
}

function rezani_pvp() 
{
    if (!Player.Dead()) 
    {
           var corpses = Orion.FindType('0x2006', '-1', ground, '', 'usedistance');
            for (var c = 0; c < corpses.length; c++) 
            {
                   Orion.UseObject('self');
                   Orion.Wait(300);
                   Orion.WaitTargetObject(corpses[c]);
                   Orion.UseObject('ba');
                   Orion.Wait(1000);
                   Orion.UseObject('kun');
            }
            Orion.Wait(200);
      }
}

