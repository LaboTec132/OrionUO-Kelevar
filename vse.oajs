 {
 
    var container = Orion.FindObject("nastroj");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac nastroj na vyrobu");
        Orion.AddObject("nastroj"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("bedna_na_drevo");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac bednu na drevo");
        Orion.AddObject("bedna_na_drevo"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    var container = Orion.FindObject("bedna_na_kindling");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac bednu na kindling");
        Orion.AddObject("bedna_na_kindling"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }
    
    
     while(!Player.Dead())
    {  

    
        
          
        if (Orion.Count('0x0DE1') > 100)  // Kindling
        {           
            Orion.UseObject("bedna_na_kindling")
            Orion.Wait(1000);
            Orion.MoveItem(Orion.FindType('0x0DE1', '0x0000', backpack)[0], (0 - Orion.Count('0x0DE1', '0x0000', "bedna_na_kindling")), 'bedna_na_kindling');  
         }
        
        if (Orion.Count('0x1BDD') < 10)  // Drevo
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_drevo")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(101));   
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
            Orion.Wait(300); 
        }
        
        Orion.ClearJournal();   
        Orion.CancelWaitMenu(); 
        Orion.CancelWaitGump();
        
        Orion.WaitMenu("What do you want to carve", "kindling");
        Orion.WaitTargetType('0x1BDD');
        Orion.UseObject("nastroj");
        Orion.WaitJournal('nepovedlo|Vkladas', Orion.Now(), Orion.Now()+10000, 'My|Sys'); 
        Orion.Wait(100); 
    }    
}

