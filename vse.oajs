function inviska()
 {
 	Orion.ClearJournal(); 
    if (Player.WarMode(true))
       {  
            if (Orion.Count("0x0F09", "0x0810") < 1)
            {
            Orion.CharPrint(self, "33", "** DOSLY LAHVE **");
            Orion.ClearJournal(); 
            Orion.Terminate("inviska");  
            }
        
        Orion.WarMode(false);               
        Orion.Wait(100);     
        Orion.Say('.lektvar Invisibility potion');
        Orion.Wait(800);  
                      
            if (Orion.InJournal("Nepotrebujes", "sys")){
            Orion.CharPrint(self, "52", "--- Nemuzes pit ---");
            Orion.ClearJournal(); 
            Orion.Terminate("inviska");  
            }  
            
            if (Orion.InJournal("nemuzes pit", "sys")){
            Orion.CharPrint(self, "52", "--- Nemuzes pit ---");
            Orion.ClearJournal(); 
            Orion.Terminate("inviska");  
            }             

  		    Orion.AddDisplayTimer(100, 14900, 'Custom', 'Circle|Bar', 'Lahev', 148, 510, '0x0049', 0, 'green');       
        }
    else
        {           
            if (Orion.Count("0x0F09", "0x0810") < 1)
            {
            Orion.CharPrint(self, "33", "** DOSLY LAHVE **");
            Orion.ClearJournal(); 
            Orion.Terminate("inviska");  
            }
               
   		    Orion.Say('.lektvar Invisibility potion');
            Orion.Wait(800);  
                      
            if (Orion.InJournal("Nepotrebujes", "sys")){
            Orion.CharPrint(self, "52", "--- Nemuzes pit ---");
            Orion.ClearJournal(); 
            Orion.Terminate("inviska");  
            }  
            
            if (Orion.InJournal("nemuzes pit", "sys")){
            Orion.CharPrint(self, "52", "--- Nemuzes pit ---");
            Orion.ClearJournal(); 
            Orion.Terminate("inviska");  
            }             

		   Orion.AddDisplayTimer(100, 14900, 'Custom', 'Circle|Bar', 'Lahev', 148, 510, '0x0049', 0, 'green');  
        }    
}

