function  NAKUP() 
{

	var material = Orion.FindType("0x0E34","0x0000",backpack);
	var vendor = Orion.FindObject("blanky_vendor");
	var lootsacek = Orion.FindObject("lootsacek");
			
		if (!vendor)
			{
	        Orion.CharPrint(self, "42", "Oznac vendora na blanky");
	        Orion.AddObject("blanky_vendor"); 
	        Orion.Wait(100);
	        while (Orion.HaveTarget())
		        {
		            Orion.Wait(100);
		        }
			}
			
		if (!lootsacek)
			{
	        Orion.CharPrint(self, "42", "Oznac sacek na loot");
	        Orion.AddObject("lootsacek"); 
	        Orion.Wait(100);
	        while (Orion.HaveTarget())
		        {
		            Orion.Wait(100);
		        }
			}
			
		while (!Player.Dead() | Player.Gold > 5000 | (Player.Weight - 45) < Player.MaxWeight)
			{
				Orion.Wait(100);
				Orion.MoveItem("",0,"lootsacek",5,5);
                while (Orion.HaveTarget())
                	{
                		Orion.TargetObject("0x0E34","0x0000",backpack);
                		Orion.Wait(200);
                	}
				Orion.Follow(vendor, true);
				Orion.Wait(250);
				Orion.Buy("autobuy","",[500]);
				Orion.Wait(100);
				Orion.CloseGump("shop",any,any);
				Orion.Wait(300000);
			}
}  

