        {
            Orion.Wait(100);
        }
    }
     
     while(!Player.Dead())
    {  

    
        
        if (Orion.Count('0x0978') > 100)  // SLANINA
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_jidlo")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(3)); 
            Orion.WaitTargetType("0x0978");
            Orion.Wait(800);        
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));  
            Orion.Wait(300); 
        }

        if (Orion.Count('0x0F84') < 25)  // Garlic
        {           
            Orion.UseObject("bedna_s_regama")
            Orion.Wait(1000);
            Orion.MoveItem(Orion.FindType('0x0F84', '0x0000', "bedna_s_regama")[0], (150 - Orion.Count('0x0F84', '0x0000', backpack)), backpack);  
         }
         
        if (Orion.Count('0x0DE1') < 20)  // Kingling
        {           
            Orion.UseObject("bedna_s_regama")
            Orion.Wait(1000);
            Orion.MoveItem(Orion.FindType('0x0DE1', '0x0000', "bedna_s_regama")[0], (100 - Orion.Count('0x0DE1', '0x0000', backpack)), backpack);  
         }
        
        if (Orion.Count('0x0976') < 25)  // Slabs of bacon
        {           
            Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("bedna_na_jidlo")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(102)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(102));
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(102));
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1000));   
            Orion.Wait(300); 
        }
        
        Orion.ClearJournal();   
        Orion.CancelWaitMenu(); 
        Orion.CancelWaitGump();
            var Gump;
                Orion.Wait(800);
                Orion.UseObject("kucharka")
                Orion.Wait(1000);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(112)); 
            Orion.Wait(800);
            var Gump;
                Orion.Wait(600);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(100));
            
            Orion.Wait(600);
            var ohen = Orion.FindType("0x0DE3", "0x0000", ground, "ignoreself", 3);  // ohen
            Orion.Wait(100);
                        
            if (!ohen.length != 0)
            {
                    var kindling = Orion.FindType("0x0DE1"); 
                           
                    for (var r in kindling) {   
                    Orion.Drop(kindling[r], 1, Player.X() , Player.Y() + 1, Player.Z());
                    Orion.Wait(800);
                    Orion.UseType('0x0DE1','0x0000', 'ground')
                    }               
            }   
  

        
        Orion.Wait(1500);
        Orion.UseType('0x0DE3','0x0000', 'ground')
        Orion.WaitJournal('Nejdriv si vyber|nepovedlo|Vkladas', Orion.Now(), Orion.Now()+10000, 'My|Sys');   
        Orion.Wait(100); 
        Orion.UseType('0x0DE3','0x0000', 'ground')
        Orion.WaitJournal('Nejdriv si vyber|nepovedlo|Vkladas', Orion.Now(), Orion.Now()+10000, 'My|Sys');   
        Orion.Wait(100); 
        Orion.UseType('0x0DE3','0x0000', 'ground')
        Orion.WaitJournal('Nejdriv si vyber|nepovedlo|Vkladas', Orion.Now(), Orion.Now()+10000, 'My|Sys');   
        Orion.Wait(100); 
        Orion.UseType('0x0DE3','0x0000', 'ground')
        Orion.WaitJournal('Nejdriv si vyber|nepovedlo|Vkladas', Orion.Now(), Orion.Now()+10000, 'My|Sys');   
        Orion.Wait(100); 
