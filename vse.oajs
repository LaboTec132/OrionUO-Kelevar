function perfreeze_kill()
{
    Orion.ClearJournal();
    Orion.WaitTargetObject('cil');
    Orion.Say("Volam mraz na nepritele");
    Orion.Wait(500);    
        if (Orion.InJournal("see the target", 'sys')) {
        Orion.Print("****! VYPINAM !****");
        Orion.Terminate('perfreeze_kill');  
        }
        if (Orion.InJournal("neni v linii", 'sys')) {
        Orion.Print("****! VYPINAM !****");
        Orion.Terminate('perfreeze_kill');  
        }     
        Orion.ClearJournal();
        while (!Orion.InJournal("You hit", 'sys')) {
            Orion.Wait(100);            
        }
    Orion.WaitTargetObject('cil');
    Orion.Say("all kill");
    Orion.Wait(200); 
    Orion.Exec("perfreeze_kill")
}

function spinac_perfreeze()
