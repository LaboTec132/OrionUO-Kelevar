function poustim_Hledani_houba()
{
Orion.CharPrint(self, "82", "*Zapnuto hledani houby*");
while(!Player.Dead())
    {                    
            var target1 = Orion.FindType("0x0D19", "0x0794", ground, "ignoreself", 30);  // Fungus magicus
            Orion.Wait(100);
                        
            if (target1.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN FUNGUS !***");                  
                    targetobject = Orion.FindObject(target1[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
                    if (Orion.GetDistance(target1[0]) <= 2)
                    {          
                        Orion.SetTrack (false, targetobject.X(), targetobject.Y());
                        Orion.Wait(200);
                        Orion.UseObject(target1[0]);
                        Orion.Wait(500);                      
                    }
            }          

            Orion.Wait(1000); 
    }                
}

