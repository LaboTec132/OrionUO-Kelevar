function Hledani_ebony_silver()
{
Orion.CharPrint(self, "82", "*Zapnuto hledani stromu*");
while(!Player.Dead())
    {                    
            var target1 = Orion.FindType("0x0CE0", "0x0454", ground, "ignoreself", 40);  // ebony tree
            Orion.Wait(100);
                        
            if (target1.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN EBONY TREE !***");                  
                    targetobject = Orion.FindObject(target1[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
                    if (Orion.GetDistance(target1[0]) <= 2)
                    {          
                        Orion.SetTrack (false, targetobject.X(), targetobject.Y());
                        Orion.Wait(300);                      
                    }
            }                 
                
            var target2 = Orion.FindType("0x0D94", "0x07A1", ground, "ignoreself", 40);   // silver tree 
            Orion.Wait(100);  
                      
            if (target2.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN SILVER TREE !***");                  
                    targetobject = Orion.FindObject(target2[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
                    if (Orion.GetDistance(target2[0]) <= 2)
                    {          
                        Orion.SetTrack (false, targetobject.X(), targetobject.Y());
                        Orion.Wait(300);                      
                    }
            }           

            Orion.Wait(1000); 
    }                
}

