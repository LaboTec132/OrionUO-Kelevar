function hp()
{
Orion.CharPrint(self, "42", "***! ZAPNUTO !***");
    while(!Player.Dead())
    {                
                if (Player.Hits() < 30)
                   {   
                      Orion.Say(".maxusvitum");                        
                      Orion.ClearJournal();  
                      Orion.Wait(100); 
                         if (Orion.InJournal("limit ti br", 'sys'))
                         {
                              Orion.Say(".jidlo pizza sunkova"); 
                              Orion.Wait(500); 
                         }     
                   }
       }
}

function hp_mag()
{
Orion.CharPrint(self, "42", "***! ZAPNUTO !***");
    while(!Player.Dead())
    {                
                if (Player.Hits() < 30)
                   {   
                      Orion.Say(".jidlo pizza sunkova");  
                      Orion.Wait(300); 
                   }
       }
}

function Hledani_svitek_trezor(){
            Orion.Terminate('hledani');
            Orion.Wait(200); 
            Orion.Exec('hledani');
}

function hledani()
{
Orion.CharPrint(self, "72", "***! ZAPNUTO !***");
while(!Player.Dead())
    { 
                   
            var target1 = Orion.FindType("0x0E34", "-1", ground, "ignoreself", 30);  // svitek
            Orion.Wait(100);
            
            if (target1.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN SVITEK !***");                  
                    targetobject = Orion.FindObject(target1[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            } 
                
                
            var target2 = Orion.FindType("0xEB41|0xED1C", "-1", ground, "ignoreself", 30);  // trezor ve zdi 
            Orion.Wait(100);
            
            if (target2.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN TREZOR VE ZDI !***");                  
                    targetobject = Orion.FindObject(target2[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            }  
            
            var target3 = Orion.FindType("0xEEBD", "-1", ground, "ignoreself", 30);  // trezor nazemi 
            Orion.Wait(100);
            
            if (target3.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN TREZOR NA ZEMY !***");                  
                    targetobject = Orion.FindObject(target3[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            } 
            
            var target4 = Orion.FindType("0x09A8", "-1", ground, "ignoreself", 30);  // wooden box  
            Orion.Wait(100);
            
            if (target4.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN WOODEN BOX !***");                  
                    targetobject = Orion.FindObject(target4[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            } 
            
            var target5 = Orion.FindType("0x3CA3", "-1", ground, "ignoreself", 30);  // kovana truhla 
            Orion.Wait(100);
            
            if (target5.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZEN KOVANA BEDNA !***");                  
                    targetobject = Orion.FindObject(target5[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            } 
            
            var target6 = Orion.FindType("0x0FF2", "0x0A0F", ground, "ignoreself", 30);  // kniha 
            Orion.Wait(100);
            
            if (target6.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZENA KNIHA !***");                  
                    targetobject = Orion.FindObject(target6[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            } 
            
            var target7 = Orion.FindType("-1", "0x0788", ground, "ignoreself", 30);  // COKOLIV 
            Orion.Wait(100);
            
            if (target7.length != 0)
            {
                    Orion.CharPrint(self, "42", "***! NALEZENO NECO V BARVE SVITKU !***");                  
                    targetobject = Orion.FindObject(target7[0]);
                    Orion.SetTrack (true, targetobject.X(), targetobject.Y());
            }
            
            var target8 = Orion.FindType("0x09A8", "-1", ground, "ignoreself", 30);  // KLICENKA WOODENBOX
            Orion.Wait(100);
            
            if (target8.length != 0)
