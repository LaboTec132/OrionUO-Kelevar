function autotarget()
{
    for (var ind = 0; ind < 2; ind++)
    {        
        var mobileID = Orion.FindEnemy('near|ignoreself|ignorefriends',20); 

        if (mobileID.length != 0)
        {
            var enemyObj = Orion.FindObject(mobileID);
          

        
            if (enemyObj)
            {            
                Orion.CharPrint(self, "33", "" + Orion.RequestName(mobileID) + " " + enemyObj.Hits("%") + "%");
                Orion.CharPrint(mobileID, "33", "Target: " + Orion.RequestName(mobileID) + "");                
            }
            
            Orion.ClearHighlightCharacters ([priorityHighlight = false]);
            Orion.CloseStatusbar("cil")  
            Orion.AddObject("cil", mobileID);  
            Orion.SetGlobal("global_enemy", mobileID);
            Orion.ClientLastTarget(mobileID);
            Orion.TargetSystemSerial(mobileID); 
            Orion.ShowStatusbar("cil", -12,496)     
            Orion.AddHighlightCharacter('lasttarget', '33', [priorityHighlightList=true]);                   
            Orion.Ignore(mobileID);            
            return;              

        }
        else if (ind == 0)
        {
            
        }
    }
   Orion.Exec('autotarget2'); 
}

function autotarget2()
{
    for (var ind = 0; ind < 2; ind++)
    {
        var mobileID = Orion.FindType("-1", "-1", "ground", "near|live|ignorefriends|ignoreself", 14, "red|criminal|enemy");

        if (mobileID.length != 0)
        {
            var enemyObj = Orion.FindObject(mobileID[0]);

            var notoColor;

            if (enemyObj)
            {
                switch (enemyObj.Notoriety())
                {
                    case 1:
                        notoColor = 66; // blue
                        break;

                    case 3:
                        notoColor = 55; // gray
                        break;

                    case 6:
                        notoColor = 33; // red
                        break;

                    default:
                        notoColor = 22;
                }

                Orion.CharPrint(self, notoColor, "" + Orion.RequestName(mobileID[0]) + " " + enemyObj.Hits("%") + "%");
                Orion.CharPrint(mobileID[0], notoColor, "Target: " + Orion.RequestName(mobileID[0]) + "");                
            }
            
            Orion.ClearHighlightCharacters ([priorityHighlight = false]);
            Orion.CloseStatusbar("cil")  
            Orion.AddObject("cil", mobileID);  
            Orion.SetGlobal("global_enemy", mobileID[0]);
            Orion.ClientLastTarget(mobileID[0]);
            Orion.TargetSystemSerial(mobileID[0]); 
            Orion.ShowStatusbar("cil", -12,496)     
            Orion.AddHighlightCharacter('lasttarget', '33', [priorityHighlightList=true]);                   
            Orion.Ignore(mobileID[0]);            
            return;        

        }
        else if (ind == 0)
        {
            Orion.IgnoreReset();
        }
    }
 
    Orion.CharPrint(self, "82", "* Zadny Target *");    
}

