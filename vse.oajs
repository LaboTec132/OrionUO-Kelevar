function portdomu()
 {
    if (Player.WarMode(true))
       {   
        Orion.WarMode(false);               
        Orion.Wait(100);         
        var Gump;
            Orion.UseObject("rb");
            Orion.Wait(500);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(2));              
        }
    else
        {       
        var Gump;
            Orion.UseObject("rb");
            Orion.Wait(500);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(2));
        }    
}

