function Alkac_vendor()
{
     while(!Player.Dead())
    {
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2)); 
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));  
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2011)); 
            Orion.Wait(500);
            
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(1)); 
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));  
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2006));
            Orion.Wait(100);
            var Gump;
                Orion.Wait(400);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(2011)); 
            Orion.Wait(500);
    }
}

function posun_sacku()
{
    var container = Orion.FindObject("posun_sacek");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac sacek kterej budes posouvat");
        Orion.AddObject("posun_sacek"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }    
    
while(!Player.Dead())
    {
        if (Orion.GetDistance("posun_sacek") == 2|Orion.GetDistance("posun_sacek") == 1 )
        {
            Orion.DropHere("posun_sacek");
            Orion.Say("dgdbs"); 
        }
        Orion.Wait(200);
    }       
}

function hozeni_itemu_pod_sebe()
{
var banda = Orion.FindType("0x0E21"); 
       
for (var r in banda) {
Orion.DropHere(banda[r],1);    
}
}

function ohen()
{
    Orion.WarMode("off")   
    Orion.UseType('0x0DE1'); 
    Orion.Wait(100);
    Orion.UseType('0x0DE3','0x0000', 'ground')   
       Orion.ClearJournal(); 
       while (!Orion.InJournal("jsi ruce nad" , 'sys')) {
                   Orion.UseType('0x0DE3','0x0000', 'ground') 
                   Orion.Wait(500);
       } 
}      

function Drop_policko_od_sebe()
{
var banda = Orion.FindType("0x0B3F"); 
       
for (var r in banda) {   
Orion.Drop(banda[r], 1, Player.X() , Player.Y() + 1, Player.Z());
}
}



