function Loot_ze_zeme()
{

    var container = Orion.FindObject("lootsacek");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac loot sacek");
        Orion.AddObject("lootsacek");
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }    
 
    var list = Orion.FindList('lootlist_zem', ground);
    for (var i = 0; i < list.length; i++)
    {      
       Orion.MoveItem(list[i], 0, "lootsacek");
       Orion.Wait(600);
    }    
}

