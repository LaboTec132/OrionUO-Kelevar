function zapaleni_ohne()
{
var maps = Orion.FindType("0x0DE1");
{
for (var r in maps) {
    Orion.WarMode("off")
    Orion.DropHere(maps[r],1);    
    Orion.UseType('0x0DE1'); 
    Orion.Wait(100);
    Orion.UseType('0x0DE3','0x0000', 'ground')   
       Orion.ClearJournal(); 
       while (!Orion.InJournal("jsi ruce nad" , 'sys')) {
                   Orion.UseType('0x0DE3','0x0000', 'ground') 
                   Orion.Wait(500);
       }    
}
}
}

function nasazeni_stitu_a_zbrane1()
{
    if (Player.Weight() > Player.MaxWeight() - 1)   
       {
       Orion.CharPrint(self, "42", "****! PRETIZENI !****");
       Orion.CharPrint(self, "52", "****! PRETIZENI !****");  
       Orion.CharPrint(self, "42", "****! PRETIZENI !****");               
        }
    else
        {       
       Orion.Equip('stit');
       Orion.Wait(500);
       Orion.Equip('zbran1');
        }    
}

