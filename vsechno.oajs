function recover_z_bile()
{
    var rightHandObj = Orion.ObjAtLayer("RightHand");
    var leftHandObj = Orion.ObjAtLayer("LeftHand");
    

    Orion.Say("Vas An Nox Sanct");     
    Orion.Wait(2000);
    
    if (rightHandObj)
    {
        Orion.Equip(rightHandObj.Serial());
        Orion.Wait(600);
    }
    
    if (leftHandObj)
    {
        Orion.Equip(leftHandObj.Serial());
        Orion.Wait(600);
    }
    
}

