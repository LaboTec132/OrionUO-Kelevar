function track_animal()
 {
    if (Player.WarMode(true))
       {   
        Orion.WarMode(false);               
        Orion.Wait(100);     
        Orion.CancelWaitGump();
        var Gump;
            Orion.UseSkill("Tracking");
            Orion.Wait(400);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(1));              
        }
    else
        {
        Orion.CancelWaitGump();
        var Gump;
            Orion.UseSkill("Tracking");
            Orion.Wait(400);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(1));
        }    
}

function track_next()
 {  
        Orion.CancelWaitGump();
        var Gump;
            Orion.Wait(100);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(1000));              
}

function buy_artefakt()
{      

    var container = Orion.FindObject("runebook");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac runebook");
        Orion.AddObject("runebook");
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }  

    while(!Player.Dead())
    {
       if (Player.WarMode(true))       // port  1
       {   
        Orion.WarMode(false);               
        Orion.Wait(100);   
       }      
        var Gump;
            Orion.UseObject("runebook");
            Orion.Wait(500);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(16));   // pozice v RB
        Orion.Wait(10000);
        Orion.Buy('artefakt', "", [500]); 
        Orion.Wait(3000);
        
        if (Player.WarMode(true))       // port  2
       {   
        Orion.WarMode(false);               
        Orion.Wait(100);  
       }       
        var Gump;
            Orion.UseObject("runebook");
            Orion.Wait(500);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(16));    // pozice v RB
        Orion.Wait(10000);      
        Orion.Buy('artefakt', "", [500]); 
        Orion.Wait(590000);
    }
} 

function posun_sacku()
{
    var container = Orion.FindObject("posun_sacek");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac sacek kterej budes posouvat");
        Orion.AddObject("posun_sacek"); 
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }    
    
while(!Player.Dead())
    {
        if (Orion.GetDistance("posun_sacek") == 2|Orion.GetDistance("posun_sacek") == 1 )
        {
            Orion.DropHere("posun_sacek");
            Orion.Say("dgdbs"); 
        }
        Orion.Wait(200);
    }       
}

function Vykup_spec_regu_bez_uklidu()
{ 
    
    while(!Player.Dead())
    {
            Orion.Buy('spec_regy', "", [500]);            
            Orion.Wait(600000); 
    }    
}

function Vykup_spec_regu_s_uklidem_do_banky()
{
    var container = Orion.FindObject("saceknaregy");
    if (!container)
    {
        Orion.CharPrint(self, "42", "Oznac sacek na spec regy");
        Orion.AddObject("saceknaregy");
        Orion.Wait(100);
        while (Orion.HaveTarget())
        {
            Orion.Wait(100);
        }
    }     
    
    while(!Player.Dead())
    {
            Orion.Buy('spec_regy', "", [500]);
            Orion.Wait(2000);
            
            var list = Orion.FindList('spec_regy', backpack);
            for (var i = 0; i < list.length; i++)
            {      
                Orion.MoveItem(list[i], 0, "saceknaregy");
                Orion.Wait(700);
            }
            
            Orion.Wait(580000); 
    }    
}

function spoustec_invisky(){
            Orion.Terminate('Invis_opakovacka');
            Orion.Wait(200); 
            Orion.Exec('Invis_opakovacka');
}

function Invis_opakovacka()
{
    while(!Player.Dead())
    {
            Orion.ClearJournal();
            Orion.WaitTargetObject('self');             
            Orion.Cast('Invisibility')
            Orion.Wait(500);
            Orion.WaitJournal('The spell fizzles', Orion.Now(), Orion.Now()+8000, 'My|Sys'); 
            
            
            if (Orion.InJournal('The spell fizzles', 'My|Sys')) {                   
                    Orion.Exec('spoustec_invisky');
            }         

            Orion.Wait(250000); 
    }    
}

function in_corp()
 {     
    Orion.WaitTargetObject('cil');             
