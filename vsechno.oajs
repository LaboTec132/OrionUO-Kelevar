}

function rejuv()
{

			if (Orion.Count("0x0F09", "0x08A7") < 1)      // rejuv
			{
                if (Orion.Count("0x0F09", "0x0388") < 1)     // tmr
                {
                    Orion.Print("---- NEMAS TMR ----");           
                    Orion.Terminate("rejuv");  
                } 
                Orion.Print("* DOSLY TMR *");
                Orion.ClearJournal(); 
                Orion.Say('.lektvar Total mana refresh potion'); 
                Orion.Wait(800);                
                if (Orion.InJournal("Nepotrebujes", "sys")){
                Orion.CharPrint(self, "62", "---- Full HP ----");
                Orion.ClearJournal(); 
                Orion.Terminate("rejuv");  
                }  
            
                if (Orion.InJournal("nemuzes pit", "sys")){
                Orion.CharPrint(self, "52", "--- Jeste ne! ---");
                Orion.ClearJournal(); 
                Orion.Terminate("rejuv");  
                } 
            
                Orion.AddDisplayTimer(100, 14900, 'Custom', 'Circle|Bar', 'Lahev', 310, 756, '0x0049', 0, 'green');
                Orion.Terminate("rejuv"); 
            }
            
            Orion.ClearJournal();    
            Orion.Wait(100);
            Orion.Say(".lektvar Rejuvenation potion");
            Orion.Wait(800);  
                      
            if (Orion.InJournal("Nepotrebujes", "sys")){
            Orion.CharPrint(self, "52", "--- Nemuzes pit ---");
            Orion.ClearJournal(); 
            Orion.Terminate("rejuv");  
            }  
            
            if (Orion.InJournal("nemuzes pit", "sys")){
            Orion.CharPrint(self, "52", "--- Nemuzes pit ---");
            Orion.ClearJournal(); 
            Orion.Terminate("rejuv");  
            }             

   Orion.AddDisplayTimer(100, 14900, 'Custom', 'Circle|Bar', 'Lahev', 310, 756, '0x0049', 0, 'green');      
}

