function tracking_player()
 {
    if (Player.WarMode(true))
       {   
        Orion.WarMode(false);               
        Orion.Wait(100);     
        Orion.CancelWaitGump();
        var Gump;
            Orion.UseSkill("Tracking");
            Orion.Wait(400);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(4));              
        }
    else
        {
        Orion.CancelWaitGump();
        var Gump;
            Orion.UseSkill("Tracking");
            Orion.Wait(400);
        Gump = Orion.GetLastGump();
        Gump.Select(Orion.CreateGumpHook(4));
        }    
}

function per_tracking_player()
{
    while(!Player.Dead())
    {
            if (Player.WarMode(true))
           {   
            Orion.WarMode(false);               
            Orion.Wait(100);     
            Orion.CancelWaitGump();
            var Gump;
                Orion.UseSkill("Tracking");
                Orion.Wait(200);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(4));              
            }            
        else
            {
            Orion.CancelWaitGump();
            var Gump;
                Orion.UseSkill("Tracking");
                Orion.Wait(200);
            Gump = Orion.GetLastGump();
            Gump.Select(Orion.CreateGumpHook(4));
            }  
    Orion.Wait(2000);
    }
}

function rezani() 
{
    if (!Player.Dead()) 
    {
           var corpses = Orion.FindType('0x2006', '-1', ground, '', 'usedistance');
            for (var c = 0; c < corpses.length; c++) 
            {
                   Orion.OpenContainer(corpses[c])
                   Orion.Wait(200);
                   Orion.WaitTargetObject(corpses[c]);
                   Orion.UseObject('zbran2');
                Orion.ResetIgnoreList();
                Orion.Wait(200);
                Orion.Ignore(corpses[c]);
                   Orion.Wait(200);
            }
            Orion.Wait(200);
      }
}

