function autotarget()
{
    for (var ind = 0; ind < 2; ind++)
    {
        var mobileID = Orion.FindType("-1", "-1", "ground", "near|live|ignorefriends|ignoreself", 12, "red|criminal");

        if (mobileID.length != 0)
        {
            var enemyObj = Orion.FindObject(mobileID[0]);

            var notoColor;

            if (enemyObj)
            {
                switch (enemyObj.Notoriety())
                {
                    case 1:
                        notoColor = 66; // blue
                        break;

                    case 3:
                        notoColor = 55; // gray
                        break;

                    case 6:
                        notoColor = 33; // red
                        break;

                    default:
                        notoColor = 22;
                }

                Orion.CharPrint(self, notoColor, "" + Orion.RequestName(mobileID[0]) + " " + enemyObj.Hits("%") + "%");
                Orion.CharPrint(mobileID[0], notoColor, "Target: " + Orion.RequestName(mobileID[0]) + "");                
            }
            
            Orion.ClearHighlightCharacters ([priorityHighlight = false]);
            Orion.CloseStatusbar("cil")  
            Orion.AddObject("cil", mobileID);  
            Orion.SetGlobal("global_enemy", mobileID[0]);
            Orion.ClientLastTarget(mobileID[0]);
            Orion.TargetSystemSerial(mobileID[0]); 
            Orion.ShowStatusbar("cil", 850,744)     
            Orion.AddHighlightCharacter('lasttarget', '33', [priorityHighlightList=true]);                   
            Orion.Ignore(mobileID[0]);            
            return;        

        }
        else if (ind == 0)
        {
            Orion.IgnoreReset();
        }
    }
 
    Orion.CharPrint(self, "82", "* Zadny Target *");    
}

function sber_bavlny()
{
    while(!Player.Dead())
    {
        var bavlna = Orion.FindType('0x0C4F', '0x0000', 'ground', 'near', '2');
        for (var c = 0; c < bavlna.length; c++)
        {
            var serial = bavlna[c];
            Orion.UseObject(serial);
            Orion.Wait(1800);
        }
    }
}

function targetdraka() {
    Orion.Ignore(self);
    var target = Orion.FindType("0x02CE", "0x02ED", "ground", "mobile", 10, "gray");
    if (target.length != 0) {
        Orion.AddObject("drak", target);
        Orion.ShowStatusbar("drak", 850,744)
        Orion.Ignore(target[0]);
    } else {
        Orion.IgnoreReset();
        Orion.Ignore(self);
        target = Orion.FindType("0x02CE", "0x02ED", "ground", "mobile", 10, "gray");
        if (target.length != 0) {
            Orion.AddObject("drak", target); 
            Orion.ShowStatusbar("drak", 850,744)      
            Orion.Ignore(target[0]);
        }
    }
}

function drakrozbaleni()
{
    var rightHandObj = Orion.ObjAtLayer("RightHand");
    var leftHandObj = Orion.ObjAtLayer("LeftHand");
    
    if (Player.Weight() > Player.MaxWeight() - 1)   
       {
       Orion.CharPrint(self, "42", "****! PRETIZENI !****");
       Orion.CharPrint(self, "52", "****! PRETIZENI !****");  
       Orion.CharPrint(self, "42", "****! PRETIZENI !****");               
        }
    else
        {       
       Orion.Equip('0x4263F862');
       Orion.Wait(10);
       Orion.UseType("0x20D6")
       Orion.Wait(300);
       Orion.Say("all come")
       Orion.Exec('targetdraka');
       Orion.Wait(500);
        }    
        
    if (rightHandObj)
    {
        Orion.Equip(rightHandObj.Serial());
        Orion.Wait(600);
    }
    
    if (leftHandObj)
    {
        Orion.Equip(leftHandObj.Serial());
        Orion.Wait(600);
    }
}

function drakbandy()
{
    while(!Player.Dead())
    {
            Orion.ClearJournal();
            Orion.WaitTargetObject('drak');
            Orion.UseType('0x0E21');
            Orion.Wait(500);            
            if (Orion.InJournal("Nepotrebuje vylecit", 'sys')) {
            Orion.CharPrint(self, "42", "** OK VYPINAM **");
            Orion.Terminate('drakbandy');  
            }
            if (Orion.InJournal("Jdi bliz!", 'sys')) {
            Orion.CharPrint(self, "42", "****! Jdi blize !****");
            Orion.Wait(1000); 
            Orion.Exec('spoustecbandu');
            }
            Orion.ClearJournal();
            while (!Orion.InJournal("podarila", 'sys')) {
                Orion.Wait(1000);
            }
    }
}

function spoustecbandu(){
            Orion.Terminate('drakbandy');
            Orion.Wait(200); 
            Orion.Exec('drakbandy');
}

