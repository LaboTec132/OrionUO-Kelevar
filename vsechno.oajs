function per_freeze()
{
    Orion.ClearJournal();
    Orion.WaitTargetObject('cil');
    Orion.Say("Volam mraz na nepritele");
    Orion.Wait(200);
        if (Orion.InJournal("see the target", 'sys')) {
        Orion.Print("****! VYPINAM !****");
        Orion.Terminate('per_freeze');  
        }
        if (Orion.InJournal("neni v linii", 'sys')) {
        Orion.Print("****! VYPINAM !****");
        Orion.Terminate('per_freeze');  
        }     
        Orion.ClearJournal();
        while (!Orion.InJournal("You hit", 'sys')) {
            Orion.Wait(100);            
        }
    Orion.Exec("per_freeze")
}

